{
    email {$LETS_ENCRYPT_EMAIL}
    # При необходимости поднять лимит и убрать предупреждения о memory:
    servers {
        timeouts {
            read_body 30s
            read_header 10s
            write 60s
            idle 5m
        }
    }
}

{$LEGALHUB_DOMAIN} {
    # Ограничение по IP (переменная SITE_ALLOWED_IPS в compose, по умолчанию 0.0.0.0/0 ::/0 = все).
    # Путь ACME не трогаем — иначе Let's Encrypt не продлит сертификат.
    @forbidden {
        not path /.well-known/acme-challenge*
        not remote_ip {$SITE_ALLOWED_IPS}
    }
    handle @forbidden {
        respond "Forbidden" 403
    }
    handle {
        encode gzip zstd

        # Базовые security headers — корпоративная система должна выглядеть прилично.
        header {
            Strict-Transport-Security "max-age=31536000; includeSubDomains"
            X-Content-Type-Options "nosniff"
            X-Frame-Options "DENY"
            Referrer-Policy "strict-origin-when-cross-origin"
            # Уберите если будете встраивать внешние iframe / шрифты.
            Permissions-Policy "geolocation=(), microphone=(), camera=()"
        }

        # Большие выгрузки PIR-Excel могут занимать пару минут.
        reverse_proxy web:80 {
            transport http {
                response_header_timeout 120s
                read_timeout 120s
            }
        }
    }
}
