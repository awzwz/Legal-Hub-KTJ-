# Скопируйте файл: cp .env.prod.example .env.prod
# и заполните секреты СВОИМИ ЗНАЧЕНИЯМИ. .env.prod в гит не коммитится.

# --- Postgres ---
POSTGRES_USER=legalhub
POSTGRES_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__
POSTGRES_DB=legalhub

# --- Приложение ---
# Сгенерируйте: openssl rand -hex 32
JWT_SECRET=__CHANGE_ME_HEX32__
INTERNAL_API_KEY=__CHANGE_ME_INTERNAL__

# Полный публичный origin фронтенда (с https://). Бекенд проверяет CORS по этому списку.
# Допускается несколько через запятую.
CORS_ORIGINS=https://__YOUR_DOMAIN__

# --- Caddy / TLS ---
# Это домен, по которому будет доступна система. Варианты:
#   1) Свой домен:           legalhub.kt-zhol.kz
#   2) Через nip.io по IP:   3-72-10-15.eu-central-1.compute.amazonaws.com
#                            или 3.72.10.15.nip.io  (Let's Encrypt выдаёт сертификат бесплатно)
LEGALHUB_DOMAIN=__YOUR_DOMAIN__

# Email для уведомлений Let's Encrypt о скором истечении сертификата.
LETS_ENCRYPT_EMAIL=admin@example.com
