DATABASE_URL=postgresql+asyncpg://legalhub:legalhub@127.0.0.1:5432/legalhub
# Опционально: отдельные БД для микросервисов (см. deploy/DATABASE_SPLIT.md)
IAM_DATABASE_URL=
WORKSPACE_DATABASE_URL=
LEGAL_DATABASE_URL=

JWT_SECRET=change-me-use-openssl-rand-hex-32
INTERNAL_API_KEY=change-me-internal-key

REDIS_URL=redis://127.0.0.1:6379/0

# Наблюдаемость
LOG_JSON=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true

# S3-совместимое хранилище для дублирования выгрузок ПИР (опционально)
S3_ENDPOINT_URL=
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

RELAX_AUTH=true
AUTO_DDL=true
